{
  "name": "desktop-eas",
  "version": "1.0.0",
  "description": "Emergency Alert System desktop viewer",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-vite build",
    "compile": "electron-vite build",
    "dist": "npm run compile && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PickleModifications/desktop-eas.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.desktop.eas",
    "productName": "Desktop EAS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      "resources/**"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "bugs": {
    "url": "https://github.com/PickleModifications/desktop-eas/issues"
  },
  "homepage": "https://github.com/PickleModifications/desktop-eas#readme",
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/leaflet": "^1.9.21",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  }
}
